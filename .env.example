# =====================================================================
# Variables de entorno para docker compose (NO commitear el .env real)
# Copia este fichero como .env y rellena los valores.
# =====================================================================

# --- Supabase (backend) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (frontend, build-time -> se inlinea en el bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- API URLs usadas por el frontend (build-time) ---
# En local con docker compose: el frontend habla con el backend desde el navegador
# del host, así que apunta a localhost (NO a "backend" que sólo resuelve dentro de la red Docker).
VITE_ANALYSIS_API_BASE_URL=http://localhost:8000
VITE_ANALYSIS_TEXT_PATH=/predecir/
VITE_ANALYSIS_SAVE_PATH=/analyses/save
