# =====================================================================
# Variables de entorno para docker compose (NO commitear el .env real)
# Copia este fichero como .env y rellena los valores.
# =====================================================================

# --- Supabase (backend) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (frontend, build-time -> se inlinea en el bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- API URLs usadas por el frontend (build-time) ---
# En local con docker compose: el frontend habla con el backend desde el navegador
# del host, así que apunta a localhost (NO a "backend" que sólo resuelve dentro de la red Docker).
VITE_ANALYSIS_API_BASE_URL=http://localhost:8000
VITE_ANALYSIS_TEXT_PATH=/predecir/
VITE_ANALYSIS_VERIFY_PATH=/verify
VITE_ANALYSIS_SAVE_PATH=/analyses/save
VITE_ACCOUNT_DELETE_PATH=/account/delete
VITE_BILLING_CHECKOUT_PATH=/billing/checkout
VITE_BILLING_CONFIRM_PATH=/billing/confirm

# En produccion, Cloudflare Pages debe compilar el frontend con:
# VITE_ANALYSIS_API_BASE_URL=https://api.fakenewsinsight.com

# --- Stripe (backend) ---
# Obten estas claves desde https://dashboard.stripe.com (modo test)
STRIPE_SECRET_KEY=sk_test_xxx
# El webhook secret se obtiene tras crear el endpoint en Stripe (o `stripe listen` en local).
STRIPE_WEBHOOK_SECRET=whsec_xxx
# IDs de Price (no de Product) creados en Stripe para PRO y ULTRA mensuales.
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_ULTRA=price_xxx_ultra

# --- URLs de retorno de Stripe Checkout / Portal ---
# IMPORTANTE: el placeholder {CHECKOUT_SESSION_ID} debe quedar literal, Stripe lo sustituye.
BILLING_SUCCESS_URL=http://localhost:5173/dashboard?billing=success&session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=http://localhost:5173/dashboard?billing=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:5173/dashboard

# --- Agente FEVER / NLI ---
# En Docker Compose el modelo se copia dentro del contenedor en /models/.
FEVER_MODEL_PATH=/models/fever/deberta-v3-small-fever-v1
FEVER_AGENT_MAX_CLAIMS=5
FEVER_AGENT_MAX_EVIDENCES=5

# Opcionales: si faltan, el agente usa stubs deterministas.
OPENAI_API_KEY=
FEVER_LLM_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# --- CORS backend ---
# Opcional. Usalo si despliegas Cloudflare Pages con dominio propio.
# Por defecto se aceptan localhost, *.pages.dev, el antiguo frontend de Render
# y extensiones Chrome/Edge.
CORS_ALLOW_ORIGIN_REGEX=

