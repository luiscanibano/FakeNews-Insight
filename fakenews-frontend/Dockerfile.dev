# =====================================================================
# Frontend Dockerfile de desarrollo (Vite HMR)
# Uso previsto: docker-compose local con bind mount del codigo fuente.
# =====================================================================

FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]