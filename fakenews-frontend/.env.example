VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Public frontend origin used by Supabase auth redirects such as password recovery.
# This value must match the real deployed frontend origin and the allowed Redirect URLs in Supabase.
VITE_AUTH_SITE_URL=
VITE_ANALYSIS_API_BASE_URL=http://127.0.0.1:8000
# En Cloudflare Pages, configurar este valor como la URL publica del backend Render.
VITE_ANALYSIS_TEXT_PATH=/predecir/
VITE_ANALYSIS_VERIFY_PATH=/verify
VITE_ANALYSIS_SAVE_PATH=/analyses/save
VITE_ACCOUNT_DELETE_PATH=/account/delete
VITE_BILLING_CHECKOUT_PATH=/billing/checkout
VITE_BILLING_CONFIRM_PATH=/billing/confirm
