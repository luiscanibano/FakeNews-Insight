{
  "manifest_version": 3,
  "name": "FakeNews Insight",
  "short_name": "FakeNews",
  "version": "0.1.0",
  "description": "Revisa textos y verifica afirmaciones con evidencias FEVER sin salir del navegador.",
  "action": {
    "default_title": "FakeNews Insight",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "identity", "alarms"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://*.supabase.co/*",
    "https://api.fakenewsinsight.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/content.css",
        "lib/config.js",
        "lib/i18n.js",
        "lib/storage.js"
      ],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}
