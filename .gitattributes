# Normaliza finales de línea para evitar ruido entre Windows y Linux (Docker/CI)
* text=auto eol=lf

# Binarios del modelo SVM/TF-IDF (commit normal: ~220KB total)
*.pkl binary

# Imágenes y otros binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Modelo NLI FEVER exportado a ONNX
models/fever/deberta-v3-small-fever-v1/model.onnx filter=lfs diff=lfs merge=lfs -text
